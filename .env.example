# =============================================================================
# .env.example — 환경변수 템플릿
# =============================================================================
# 이 파일은 프로젝트가 요구하는 환경변수의 "키 이름"만 보여주는 템플릿이다.
# 실제 값은 이 파일에 절대 넣지 않는다 — 이 파일은 리포에 commit되며,
# .env 파일(실제 값 포함)은 .gitignore로 제외된다.
#
# 사용법:
#   1. 이 파일을 .env 로 복사한다:  cp .env.example .env
#   2. .env 파일의 <your-...> 값을 실제 값으로 교체한다.
#   3. docker compose up -d 또는 로컬 go run 으로 백엔드를 띄운다.
#
# 키 추출 근거: backend/internal/config/config.go 의 Load() 함수.
#               이 파일이 getEnv()로 읽는 7개 키를 그대로 반영한다.
#
# 주의:
#   - JWT_SECRET은 prod에서 반드시 32바이트 이상의 랜덤 값으로 교체한다.
#   - dev 기본값은 backend/internal/config/config.go 의 fallback에 있으며,
#     prod 환경에서는 이 fallback을 쓰면 안 된다 (docs/conventions/secrets.md 참조).
#   - 자세한 규칙: docs/conventions/secrets.md, docs/conventions/12-factor.md
# =============================================================================

# --- Database (PostgreSQL) ---
# PostgreSQL 호스트명 (Docker Compose 사용 시 "db", 로컬 실행 시 "localhost")
DB_HOST=<your-db-host>
# PostgreSQL 포트 (PostgreSQL 기본: 5432)
DB_PORT=<your-db-port>
# PostgreSQL 사용자명
DB_USER=<your-db-user>
# PostgreSQL 비밀번호 (dev 외에는 절대 평문으로 리포에 올리지 말 것)
DB_PASSWORD=<your-db-password>
# PostgreSQL 데이터베이스명
DB_NAME=<your-db-name>

# --- Auth (JWT) ---
# JWT 토큰 서명에 사용하는 비밀키.
# 최소 32바이트 권장. 생성 예: openssl rand -base64 48
# prod 환경에서는 AWS Secrets Manager 등 시크릿 스토어에서 주입한다.
JWT_SECRET=<your-jwt-secret>

# --- HTTP Server ---
# 백엔드 HTTP 서버가 바인드할 포트 (기본: 8080)
SERVER_PORT=<your-server-port>
